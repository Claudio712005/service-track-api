terraform {
  required_version = ">= 1.10.0"

  backend "s3" {
    bucket       = "servicetrack-tfstate-123124496645"
    key          = "servicetrack/terraform.tfstate"
    region       = "us-east-1"
    encrypt      = true
    use_lockfile = true
  }

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.60"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
  }
}

provider "aws" {
  region = var.aws_region
}
