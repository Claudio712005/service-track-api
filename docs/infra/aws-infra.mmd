%% ServiceTrack — Arquitetura AWS (fonte de verdade: infra/terraform)
%% Fallback textual do diagrama aws-infra.drawio
flowchart TB
    user(["Usuário / Cliente"])

    subgraph CLOUD["AWS Cloud"]
      direction TB

      subgraph REGION["Region · us-east-1"]
        direction TB

        ecr["Amazon ECR<br/>service-track-app · scan on push"]
        s3["S3 · Terraform State Backend<br/>servicetrack-tfstate-123124496645<br/>(backend S3 + lockfile)"]

        subgraph VPC["VPC · servicetrack-dev-vpc · 10.0.0.0/16<br/>DNS support + hostnames"]
          direction TB

          igw["Internet Gateway<br/>servicetrack-dev-igw"]
          iam["IAM Role · LabRole"]
          eks["Amazon EKS · servicetrack-dev<br/>v1.30 · endpoint público"]

          subgraph AZA["Availability Zone · us-east-1a"]
            direction TB
            subgraph PUBA["Public Subnet · 10.0.0.0/20 · us-east-1a<br/>kubernetes.io/role/elb"]
              nat["NAT Gateway<br/>servicetrack-dev-nat"]
              eip["Elastic IP"]
            end
            subgraph PRIVA["Private Subnet · 10.0.48.0/20 · us-east-1a<br/>kubernetes.io/role/internal-elb"]
              node1["Worker Node<br/>EC2 t3.medium"]
              subgraph SG["Security Group · servicetrack-dev-rds-sg<br/>ingress 5432 (só do SG do EKS) · egress all"]
                rds["RDS PostgreSQL 16.9<br/>db.t3.micro · gp3 20GB (enc.)<br/>privado · single-AZ"]
              end
            end
          end

          subgraph AZB["Availability Zone · us-east-1b"]
            direction TB
            subgraph PUBB["Public Subnet · 10.0.16.0/20 · us-east-1b<br/>kubernetes.io/role/elb"]
              pubb_empty[" "]
            end
            subgraph PRIVB["Private Subnet · 10.0.64.0/20 · us-east-1b<br/>kubernetes.io/role/internal-elb"]
              node2["Worker Node<br/>EC2 t3.medium"]
            end
          end
        end
      end
    end

    %% Auto Scaling Group (node group) abrange node1 + node2
    ASG["Auto Scaling Group · servicetrack-dev-ng<br/>desired 2 / min 1 / max 3"]

    %% Fluxo
    user -->|HTTPS 443| igw
    igw -->|HTTPS 443 · endpoint público| eks
    nat -->|0.0.0.0/0 → IGW route pública| igw
    eip -->|Elastic IP| nat
    nat -->|0.0.0.0/0 → NAT route privada · 2 subnets| PRIVA
    nat -->|0.0.0.0/0 → NAT route privada| PRIVB
    iam -.->|assume LabRole cluster & nodes| eks
    eks -->|gerencia node group| ASG
    ASG --- node1
    ASG --- node2
    node1 -->|TCP 5432| rds
    node2 -->|TCP 5432 via SG do EKS| rds
    ecr -.->|docker pull imagem| node1
    ecr -.->|docker pull imagem| node2

    classDef pub fill:#E9F3E6,stroke:#7AA116,color:#248814;
    classDef priv fill:#E6F2F8,stroke:#147EBA,color:#147EBA;
    classDef vpc fill:none,stroke:#8C4FFF,color:#8C4FFF;
    classDef region fill:none,stroke:#00A4A6,color:#147EBA,stroke-dasharray:5 5;
    classDef cloud fill:none,stroke:#232F3E,color:#232F3E;
    classDef asg fill:none,stroke:#ED7100,color:#ED7100,stroke-dasharray:5 5;
    classDef sg fill:none,stroke:#DD3522,color:#DD3522,stroke-dasharray:5 5;

    class PUBA,PUBB pub;
    class PRIVA,PRIVB priv;
    class VPC vpc;
    class REGION region;
    class CLOUD cloud;
    class ASG asg;
    class SG sg;
